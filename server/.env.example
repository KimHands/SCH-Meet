# Django
# 필수: 강력한 비밀키를 주입하세요(미설정 시 서버 기동 중단).
# 생성: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=CHANGE_ME_TO_A_STRONG_SECRET
